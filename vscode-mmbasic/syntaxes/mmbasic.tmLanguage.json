{
  "name": "MMBasic",
  "scopeName": "source.mmbasic",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#subcommands"
    },
    {
      "include": "#keywords"
    },
