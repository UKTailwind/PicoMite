# ---- Claude Code personal/local config (paths, command allowlist) ----
.claude/settings.local.json

# ---- Build trees (CMake out-of-source dirs reused across variants) ----
build/
buildRP2040L/
buildRP2350L/
_tmp/
CMakeFiles/
CMakeCache.txt

# ---- Firmware build artifacts ----
*.uf2
*.zip
*.elf
*.bin
*.hex
*.map
*.dis

# ---- Python ----
__pycache__/
*.pyc
.venv/
.venv-1/

# ---- Node (VS Code extension) ----
vscode-mmbasic/node_modules/

# ---- Generated docs / extracts ----
doxygen/html/
*.pdf
!PDF/*.pdf
_docx_extract/

# ---- Packaged VS Code extension builds ----
*.vsix

# ---- Video-converter sample/generated media (video/) keep .py/.bas/.md ----
video/*.mp4
video/*.332
video/*.r332
video/*.r332c
video/*.121
video/*.vid
video/*.aud
video/*.vc

# ---- find_static_globals.py / find_dead_globals.py accumulate caches ----
.static_scan.json
.dead_scan.json

# ---- Editor / OS / Office temp & manual backups ----
~$*
*.bak_*
*.pdf.bak*
*.tmp
dist/
